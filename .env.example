# .env.example - Copie ce fichier en .env et remplis les valeurs
# cp .env.example .env

# Anthropic Claude API (Phase 8 Brain, REQUIS)
# Genere une cle sur https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI (deprecie, plus utilise en Phase 8)
# OPENAI_API_KEY=

# Port serie Arduino
# Windows : COM3, COM4...
# Linux/Pi : /dev/ttyUSB0 ou /dev/ttyACM0
SERIAL_PORT=/dev/ttyUSB0
